# ==========================================
# Fyrsearch Sway Configuration
# ==========================================

# 1. Start Fyrsearch in the background when Sway starts
exec /opt/fyrsearch/fyrsearch

# 2. Aggressively catch the window and hide it
for_window [app_id="fyrsearch"] floating enable, move scratchpad

# 3. Toggle Fyrsearch visibility with Super + Space
bindsym Mod4+space [app_id="fyrsearch"] scratchpad show, resize set 1280 720, move position center

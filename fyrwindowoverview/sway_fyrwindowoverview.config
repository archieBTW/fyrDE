# ==========================================
# Fyrwindowoverview Sway Configuration
# ==========================================

# 1. Start Fyrwindowoverview in the background when Sway starts
exec /opt/fyrwindowoverview/fyrwindowoverview

# 2. Aggressively catch the window and hide it, but make it fullscreen when shown
for_window [app_id="fyrwindowoverview"] floating enable, border none, resize set 1920 1080, move position 0 0, move scratchpad

# ==========================================
# Fyroverview Sway Configuration
# ==========================================

# 1. Start Fyroverview in the background when Sway starts
exec /opt/fyroverview/fyroverview

# 2. Aggressively catch the window and hide it, but make it fullscreen when shown
for_window [app_id="fyroverview"] floating enable, border none, resize set 1920 1080, move position 0 0, move scratchpad

# 3. Toggle Fyroverview visibility with Super + Tab
bindsym $mod+Tab [app_id="fyroverview"] scratchpad show, border none, move absolute position 0 0

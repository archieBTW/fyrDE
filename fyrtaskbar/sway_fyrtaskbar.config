# Sway configuration for FyrTaskbar

# Launch the taskbar on startup
exec /opt/fyrtaskbar/fyrtaskbar

# Taskbar window rules
for_window [app_id="fyrtaskbar"] floating enable
for_window [app_id="fyrtaskbar"] border none
for_window [app_id="fyrtaskbar"] move position 0 0
for_window [app_id="fyrtaskbar"] sticky enable
